langchain1.2/
*/venv/
*/env/
.venv/
venv/
*.env/
.env

# ========== PyCharm 配置缓存 ==========
.idea/
*.iml
*.iws
*.swp
out/

# ========== 系统文件 ==========
.DS_Store
Thumbs.db

# ========== 日志、临时文件 ==========
*.log
logs/
